{
  "routes": [
    { "route": "/", "rewrite": "/portal.html" },
    { "route": "/aviation", "rewrite": "/aviation.html" },
    { "route": "/portal", "rewrite": "/portal.html" }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/img/*.{jpg,png,svg,ico}", "/*.{css,js}"]
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "SAMEORIGIN",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  },
  "mimeTypes": {
    ".json": "application/json"
  },
  "responseOverrides": {
    "404": {
      "rewrite": "/index.html",
      "statusCode": 200
    }
  }
}
