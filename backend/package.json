{
  "name": "lad-clpd-backend",
  "version": "1.0.0",
  "description": "Backend API for the Dubai Legal Affairs Department CLPD platform, with UAE Pass authentication",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "init-db": "node scripts/init-db.js",
    "migrate": "node scripts/migrate.js",
    "migrate:status": "node scripts/migrate.js status",
    "seed": "node scripts/seed.js",
    "seed:if-needed": "node scripts/seed-if-needed.js",
    "seed:demo": "node scripts/create-account.js --seed-demo",
    "create-account": "node scripts/create-account.js",
    "bootstrap": "bash scripts/bootstrap.sh",
    "check-env": "NODE_ENV=production node -e \"require('./src/validateEnv').validateEnv()\""
  },
  "dependencies": {
    "axios": "^1.7.7",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.3.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "nodemailer": "^6.10.1",
    "qs": "^6.13.0",
    "uuid": "^10.0.0",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
