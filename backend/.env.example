# ────────────────────────────────────────────────────────────────────────
# LAD CLPD BACKEND — ENVIRONMENT VARIABLES
# ────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in the real values before running.
# Never commit .env to source control.

# ─── Server ──────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:8080,https://lad-clpd.netlify.app

# Public URL that the frontend uses when calling the API
# Set this in the frontend at runtime: `window.LAD_API_BASE = '...'`
PUBLIC_API_BASE=http://localhost:4000

# ─── Database ────────────────────────────────────────────────────────
# SQLite (file path, default). For production, point at a Postgres URL.
DATABASE_URL=./data/lad-clpd.sqlite

# ─── JWT ─────────────────────────────────────────────────────────────
# Generate a long random string for production: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-me-with-48-random-bytes
JWT_EXPIRES_IN=8h

# ─── UAE Pass OAuth 2.0 / OpenID Connect ─────────────────────────────
# Register your service provider at https://uaepass.ae/ and you'll be issued
# a client_id and client_secret for staging and production environments.

# Environment: 'staging' or 'production'
UAEPASS_ENV=staging

# Staging credentials (UAE Pass provides these during onboarding)
UAEPASS_CLIENT_ID=sandbox_web_stage
UAEPASS_CLIENT_SECRET=sandbox_secret

# Production credentials (REQUIRED when UAEPASS_ENV=production)
UAEPASS_CLIENT_ID_PROD=
UAEPASS_CLIENT_SECRET_PROD=

# Redirect URI registered with UAE Pass (MUST match exactly)
# Staging callback for local dev — UAE Pass requires HTTPS for production
UAEPASS_REDIRECT_URI=http://localhost:4000/api/v1/auth/uaepass/callback

# After completing auth, redirect the user's browser to this frontend URL.
# The JWT and minimal profile arrive as query params (#token=…&role=…).
FRONTEND_POST_LOGIN_URL=http://localhost:8080/router.html

# OAuth scopes — 'urn:uae:digitalid:profile:general' is the standard
UAEPASS_SCOPE=urn:uae:digitalid:profile:general

# ACR (authentication context). Use 'low' for first-time SP onboarding,
# 'high' once your SP is approved for full-strength verification.
UAEPASS_ACR=urn:safelayer:tws:policies:authentication:level:low

# ─── Anthropic Claude (Lex AI panel) ─────────────────────────────────
# Used by the in-portal "Lex" assistant. Keep this server-side; the
# frontend should call /api/v1/lex/chat (proxy) instead of Anthropic directly.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ─── AI Trainer (Tavus CVI) ──────────────────────────────────────────
# The realistic-avatar 1-2-1 trainer. Keys stay server-side. Without
# TAVUS_API_KEY the /trainer/* endpoints run in demo/simulated mode.
# The REPLICA + PERSONA below are the provisioned "LAD CLPD Expert Trainer"
# (Samantha - Office V2, phoenix-3, raven-1 perception). Recreate the persona
# with: node scripts/create-trainer-persona.js
TAVUS_API_KEY=
TAVUS_REPLICA_ID=r38e4c3bc562
TAVUS_PERSONA_ID=p5b827e83144
TAVUS_PERCEPTION_MODEL=raven-1
TAVUS_MAX_CALL_DURATION_S=1800
TAVUS_ENABLE_RECORDING=false

# ElevenLabs voice for the trainer (optional). If unset, Tavus' default
# voice is used. Set both to enable ElevenLabs, then recreate the persona.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_turbo_v2_5

# ─── Rate limiting ───────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
